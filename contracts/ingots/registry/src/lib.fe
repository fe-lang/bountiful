#[test]
fn test_registry_validate_owns_lock_correct_owner() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 80)

    // Lock
    evm.call(addr: registry, gas: 100000, value: 0, message: RegistryMsg::Lock {})

    // ValidateOwnsLock with the correct owner (our address)
    let res: u256 = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::ValidateOwnsLock { owner: admin }
    )
    assert(res == 0)
}

#[test]
fn test_registry_validate_owns_lock_wrong_owner() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 81)

    // Lock (locks for our address)
