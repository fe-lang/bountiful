#[test]
fn test_registry_remove_never_registered() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 83)

    // Remove a challenge that was never registered — should succeed (sets false on non-existent)
    let res: u256 = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RemoveChallenge { challenge: Address { inner: 99999 } }
    )
    assert(res == 0)

    // Verify it's not open
    let is_open: bool = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::IsOpenChallenge { challenge: Address { inner: 99999 } }
    )
    assert(!is_open)
}

#[test]
fn test_registry_double_register() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 84)

    let challenge = Address { inner: 12345 }

    // Register once
    let res1: u256 = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RegisterChallenge { challenge }
    )
    assert(res1 == 0)

    // Register same challenge again — should succeed (idempotent)
    let res2: u256 = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RegisterChallenge { challenge }
    )
    assert(res2 == 0)

    // Should still be open
    let is_open: bool = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::IsOpenChallenge { challenge }
    )
    assert(is_open)
}

#[test]
fn test_registry_claim_already_claimed() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 85)

    // Deploy solved DummyGame
    let game = evm.create2<DummyGame>(value: 0, args: (true,), salt: 86)

    // Register, lock, claim
    evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RegisterChallenge { challenge: game }
    )
    evm.call(addr: registry, gas: 100000, value: 0, message: RegistryMsg::Lock {})
    let claim_res: u256 = evm.call(
        addr: registry, gas: 500000, value: 0,
        message: RegistryMsg::Claim { challenge: game }
    )
    assert(claim_res == 0)

    // Try to claim again — challenge is now closed
    let claim_res2: u256 = evm.call(
        addr: registry, gas: 500000, value: 0,
        message: RegistryMsg::Claim { challenge: game }
    )
    assert(claim_res2 == Error::InvalidClaim.to_int())
}

#[test]
fn test_registry_non_admin_remove() uses (evm: mut Evm) {
    // Deploy with a different admin so our caller is NOT admin
    let registry = evm.create2<BountyRegistry>(value: 0, args: (Address { inner: 999 }, 0), salt: 87)

    let res: u256 = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RemoveChallenge { challenge: Address { inner: 12345 } }
    )
    assert(res == Error::OnlyAdmin.to_int())
}

