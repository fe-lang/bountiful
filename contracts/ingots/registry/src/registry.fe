#[test]
fn test_full_bounty_flow() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 64)
    let game = evm.create2<DummyGame>(value: 0, args: (true,), salt: 65)

    // Register challenge (as admin)
    evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RegisterChallenge { challenge: game, prize_amount: 0 }
    )

    // Verify open
    let is_open: bool = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::IsOpenChallenge { challenge: game }
    )
    assert(is_open)

    // Lock the challenge
    evm.call(addr: registry, gas: 100000, value: 0, message: RegistryMsg::Lock { challenge: game })

    // Claim (game is solved)
    evm.call(
        addr: registry, gas: 500000, value: 0,
        message: RegistryMsg::Claim { challenge: game }
    )

    // Challenge closed
    let is_open: bool = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::IsOpenChallenge { challenge: game }
    )
    assert(!is_open)
}

