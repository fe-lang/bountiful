#[test]
fn test_registry_admin_register_and_check() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 56)

    // Not open initially
    let is_open: bool = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::IsOpenChallenge { challenge: Address { inner: 12345 } }
    )
    assert(!is_open)

    // Register as admin
    evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RegisterChallenge { challenge: Address { inner: 12345 }, prize_amount: 0 }
    )

    // Now open
    let is_open: bool = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::IsOpenChallenge { challenge: Address { inner: 12345 } }
    )
    assert(is_open)
}

#[test]
fn test_registry_remove_challenge_unlocked() uses (evm: mut Evm) {
    let admin = evm.address()
    let registry = evm.create2<BountyRegistry>(value: 0, args: (admin, 0), salt: 57)

    // Register
    evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RegisterChallenge { challenge: Address { inner: 12345 }, prize_amount: 0 }
    )

    // Remove while unlocked — should succeed
    evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::RemoveChallenge { challenge: Address { inner: 12345 } }
    )

    // No longer open
    let is_open: bool = evm.call(
        addr: registry, gas: 100000, value: 0,
        message: RegistryMsg::IsOpenChallenge { challenge: Address { inner: 12345 } }
    )
    assert(!is_open)
}

